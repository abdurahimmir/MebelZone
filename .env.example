# --- Backend (NestJS) ---
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL (Этап 2: Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/furniture?schema=public

# Redis (кеш, сессии, очереди — Этап 2+)
REDIS_URL=redis://localhost:6379

# JWT (Этап 3)
JWT_ACCESS_SECRET=change-me-access-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-min-16-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Google OAuth (id_token verification)
GOOGLE_CLIENT_ID=

# Local file storage (exports, renders)
STORAGE_DIR=./storage

# S3-compatible storage (MinIO: docker-compose service `minio`)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=furniture
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# SMS: POST JSON { phone, code } — опционально
SMS_WEBHOOK_URL=

# В dev: вернуть OTP в ответе /api/auth/phone/send-otp (только для отладки)
EXPOSE_DEV_OTP=true

# Подписанные cookie для /api/csrf/token (опционально, для cookie-сессий)
CSRF_COOKIE_SECRET=change-me-csrf-16chars

# Seed admin (prisma/seed.cjs)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345678

# CORS (раздельные origin для SPA и админки)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3000/api

# --- Admin (Vite) ---
# Используется админ-приложением для вызова API
VITE_API_BASE_URL=http://localhost:3000/api
