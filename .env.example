# --- Backend (NestJS) ---
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL (Этап 2: Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/furniture?schema=public

# Redis (кеш, сессии, очереди — Этап 2+)
REDIS_URL=redis://localhost:6379

# JWT (Этап 3)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# CORS (раздельные origin для SPA и админки)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:3000/api

# --- Admin (Vite) ---
# Используется админ-приложением для вызова API
VITE_API_BASE_URL=http://localhost:3000/api
