{
  "name": "furniture-web-constructor",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "npm run build -w @furniture/shared && npm run prisma:generate -w backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "prisma:generate": "npm run prisma:generate -w backend",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:admin": "npm run dev -w admin",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:admin": "npm run build -w admin",
    "lint:backend": "npm run lint -w backend",
    "test:backend": "npm run test -w backend",
    "test:backend:e2e": "npm run test:e2e -w backend"
  }
}
